# Шаблон секретов. Скопируй этот файл в secrets/ai-bot.env и впиши свои значения:
#
#   cp secrets.env.example secrets/ai-bot.env
#
# Где взять:
#   TELEGRAM_BOT_TOKEN — у @BotFather в Telegram (команда /newbot).
#   OWNER_CHAT_ID      — chat_id владельца, куда падают заявки и вопросы-эскалации.
#                        Самый простой способ: напиши своему боту любое сообщение,
#                        открой https://api.telegram.org/bot<ТОКЕН>/getUpdates
#                        и найди "chat":{"id": ... } — это и есть OWNER_CHAT_ID.
#   GIGACHAT_CREDENTIALS — авторизационный ключ (base64) из личного кабинета
#                        GigaChat API (https://developers.sber.ru/portal/products/gigachat-api).
#                        Бесплатный тариф для физлиц — scope GIGACHAT_API_PERS.
#
# Грациозная деградация:
#   - нет GIGACHAT_CREDENTIALS  -> бот живёт, на вопросы отвечает заглушкой и зовёт
#                                  оставить заявку; меню и сбор заявок работают полностью;
#   - нет TELEGRAM_BOT_TOKEN    -> запускать нечего, бот честно падает с понятной ошибкой.

TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
